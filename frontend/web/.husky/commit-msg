#!/usr/bin/env sh
# commit-msg: 校验提交信息符合 Conventional Commits 规范
# 仅对前端目录（frontend/）下的变更提交生效

# 获取暂存的文件列表，判断是否有前端文件变更
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)

# 如果暂存区有前端文件，才执行 commitlint 校验
if echo "$STAGED_FILES" | grep -q "^frontend/"; then
  "$(git rev-parse --show-toplevel)/frontend/web/node_modules/.bin/commitlint" \
    --config "$(git rev-parse --show-toplevel)/frontend/web/commitlint.config.cjs" \
    --edit "$1"
fi
