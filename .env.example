# JWT 签名密钥（必填）
# 生成方式：openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# 日志级别（可选：DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# 服务器监听地址和端口
HOST=0.0.0.0
PORT=8000

# 数据库路径（SQLite）
DATABASE_URL=sqlite:///./smart_bill.db

# 允许的跨域来源（JSON 数组格式）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
