# ============================================================
# Smart Bill — 生产环境变量
# 复制此文件为 .env，填入真实值后上传到服务器
# 注意：此文件包含密钥，严禁提交到 Git
# ============================================================

# 阿里云 DashScope API 密钥（必填）
QWEN_API_KEY=your_qwen_api_key_here

# JWT 签名密钥（必填，建议用 openssl rand -hex 32 生成）
SECRET_KEY=your_secret_key_here

# 日志级别
LOG_LEVEL=INFO

# 允许的跨域来源（JSON 数组格式，按需添加前端地址）
CORS_ORIGINS=["http://localhost:5173","http://123.56.219.4:19283"]
