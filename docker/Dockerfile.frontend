# ============================================================
# Smart Bill 前端
# 前提：在本地（deploy 脚本中）先执行 npm run build
# 本 Dockerfile 只负责：Nginx 服务预构建好的 dist
# ============================================================

FROM nginx:alpine

# 替换默认配置
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# 将预构建产物复制到 Nginx 静态目录
COPY frontend/web/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
